1. Estructura y Definición (DDL)
Crear tablas
-- Crear Tabla A
CREATE TABLE tabla_a (
    id_a INT PRIMARY KEY,
    columna_1 VARCHAR(50),
    columna_2 INT
);

-- Crear Tabla B (con llave foránea a A)
CREATE TABLE tabla_b (
    id_b INT PRIMARY KEY,
    id_a INT,
    detalle TEXT,
    FOREIGN KEY (id_a) REFERENCES tabla_a(id_a)
);
Modificar estructura
-- Añadir columna a Tabla C
ALTER TABLE tabla_c 
ADD COLUMN nueva_fecha DATE;
Eliminar estructura
-- Eliminar Tabla C (¡Cuidado!)
DROP TABLE tabla_c;
2. Manipulación de Datos (DML)
Insertar datos
-- Insertar en Tabla A
INSERT INTO tabla_a (id_a, columna_1, columna_2) 
VALUES (1, 'Ejemplo A', 100);

-- Insertar en Tabla B
INSERT INTO tabla_b (id_b, id_a, detalle) 
VALUES (10, 1, 'Relacionado con A');
Actualizar datos
-- Actualizar Tabla A
UPDATE tabla_a 
SET columna_1 = 'Nuevo Valor' 
WHERE id_a = 1;
Eliminar datos
-- Eliminar de Tabla B
DELETE FROM tabla_b 
WHERE id_b = 10;
3. Consultas Básicas (SELECT)
Selección simple
-- Seleccionar todo
SELECT * FROM tabla_a;
Filtrado y orden
SELECT columna_1 
FROM tabla_a 
WHERE columna_2 > 50 
ORDER BY columna_1 ASC;
Búsqueda por patrones
SELECT * 
FROM tabla_a 
WHERE columna_1 LIKE 'Ex%';
4. Agregaciones
-- Contar registros
SELECT COUNT(*) AS total_registros 
FROM tabla_b;

-- Sumar valores agrupados
SELECT columna_1, SUM(columna_2) 
FROM tabla_a 
GROUP BY columna_1;
5. JOINs (Relaciones entre tablas)
INNER JOIN
SELECT a.columna_1, b.detalle
FROM tabla_a a
INNER JOIN tabla_b b ON a.id_a = b.id_a;
LEFT JOIN
SELECT a.columna_1, b.detalle
FROM tabla_a a
LEFT JOIN tabla_b b ON a.id_a = b.id_a;
JOIN múltiple
SELECT a.id_a, b.detalle, c.info
FROM tabla_a a
JOIN tabla_b b ON a.id_a = b.id_a
JOIN tabla_c c ON b.id_b = c.id_b;
6. Lógica Condicional
SELECT 
    id_a,
    columna_2,
    CASE 
        WHEN columna_2 > 100 THEN 'Alto Valor'
        WHEN columna_2 BETWEEN 50 AND 100 THEN 'Valor Medio'
        ELSE 'Valor Bajo'
    END AS categoria_valor
FROM tabla_a;
7. GROUP BY + HAVING
SELECT 
    id_a, 
    COUNT(id_b) AS total_b
FROM tabla_b
GROUP BY id_a
HAVING COUNT(id_b) > 5;
8. Subconsultas
SELECT * 
FROM tabla_a
WHERE id_a IN (
    SELECT id_a 
    FROM tabla_c 
    WHERE estado = 'Activo'
);
9. CTE (Common Table Expressions)
WITH Resumen_B AS (
    SELECT id_a, COUNT(*) as conteo 
    FROM tabla_b 
    GROUP BY id_a
)
SELECT a.columna_1, r.conteo
FROM tabla_a a
JOIN Resumen_B r ON a.id_a = r.id_a;
10. Tipos de JOIN (Resumen rápido)
Tipo	Descripción
INNER JOIN	Solo coincidencias en ambas tablas
LEFT JOIN	Todo de A + coincidencias de B
RIGHT JOIN	Todo de B + coincidencias de A
FULL JOIN	Todo de ambas tablas
CROSS JOIN	Producto cartesiano
11. Ejemplo Real (Escenario de Negocio)
SELECT 
    cab.nro_factura,
    cli.nombre_cliente,
    SUM(det.precio * det.cantidad) AS total_venta,
    CASE 
        WHEN cli.region = 'Norte' THEN 'Logística A'
        ELSE 'Logística B'
    END AS centro_distribucion
FROM tabla_cabecera_A cab
JOIN tabla_detalle_B det ON cab.id_factura = det.id_factura
JOIN tabla_clientes_C cli ON cab.id_cliente = cli.id_cliente
WHERE cab.fecha >= '2024-01-01'
GROUP BY cab.nro_factura, cli.nombre_cliente, cli.region
HAVING SUM(det.precio * det.cantidad) > 1000;
12. Buenas Prácticas (Nivel Pro)
Usar PRIMARY KEY siempre
Definir FOREIGN KEY para integridad
Indexar columnas usadas en JOIN y WHERE
Evitar SELECT * en producción
Usar alias (a, b, etc.) para legibilidad
Controlar DELETE y UPDATE con WHERE
Normalizar datos (1NF, 2NF, 3NF)
Usar CTEs para queries complejas en lugar de subconsultas anidadas profundas
